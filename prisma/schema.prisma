generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model Customer {
  id        Int      @id @default(autoincrement())
  company   String
  contact   String?
  street    String?
  zip       String?
  city      String?
  email     String?
  phone     String?
  createdAt DateTime @default(now())
}