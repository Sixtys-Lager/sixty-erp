generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Customer {
  id             Int      @id @default(autoincrement())
  customerNumber String   @unique
  company        String
  contact        String?
  street         String?
  zip            String?
  city           String?
  email          String?
  phone          String?
  createdAt      DateTime @default(now())
}
